{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TypeMore",
  "version": "0.1.3",
  "identifier": "com.xnu.typemore",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "TypeMore",
        "width": 1220,
        "height": 780,
        "minWidth": 980,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "files": {
        "Frameworks/libonnxruntime.1.17.1.dylib": "target/release/libonnxruntime.1.17.1.dylib",
        "Frameworks/libsherpa-onnx-c-api.dylib": "target/release/libsherpa-onnx-c-api.dylib"
      }
    }
  }
}
